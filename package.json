{
  "name": "app_tmp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "npx --yes firebase-tools emulators:exec --only firestore,storage 'vitest run -c vitest.rules.config.ts'",
    "format": "prettier --write .",
    "emulators": "npx --yes firebase-tools emulators:start",
    "dev:emulators": "concurrently --kill-others-on-fail \"npm run dev\" \"npm run emulators\"",
    "seed:staging": "tsx scripts/seed_staging.ts",
    "seed:local": "cross-env FIREBASE_PROJECT_ID=\"remax-sales\" FIREBASE_AUTH_EMULATOR_HOST=\"127.0.0.1:9099\" FIRESTORE_EMULATOR_HOST=\"127.0.0.1:8080\" tsx scripts/seed_staging.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "next": "16.2.10",
    "papaparse": "^5.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.82.0",
    "recharts": "^3.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
